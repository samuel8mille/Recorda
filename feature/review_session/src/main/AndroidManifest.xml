<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:dist="http://schemas.android.com/apk/distribution">

    <!--
    Módulo dinâmico de exemplo, com entrega install-time (sempre instalado
    junto com o APK base). Serve de modelo para futuras features (ex.: geração
    de mapas mentais, áudio-resumos) que podem migrar para entrega sob
    demanda quando o app for distribuído via Play Feature Delivery.
    -->
    <dist:module
        dist:instant="false"
        dist:title="@string/title_review_session">
        <dist:delivery>
            <dist:install-time />
        </dist:delivery>
    </dist:module>

    <application>
        <!--
        Registers ReviewScreen into ReviewSessionEntry before Application.onCreate().
        This lets :app navigate to ReviewScreen without importing it directly,
        preserving the dynamic-feature dependency direction.
        -->
        <provider
            android:name=".ReviewSessionInitProvider"
            android:authorities="${applicationId}.review_session_init"
            android:exported="false" />
    </application>

</manifest>
