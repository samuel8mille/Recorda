<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:dist="http://schemas.android.com/apk/distribution">

    <!--
    Módulo dinâmico da sessão de memória ativa, com entrega install-time (sempre
    instalado junto com o APK base), seguindo o mesmo padrão de :feature:content.
    -->
    <dist:module
        dist:instant="false"
        dist:title="@string/title_active_recall">
        <dist:delivery>
            <dist:install-time />
        </dist:delivery>
        <dist:fusing dist:include="true" />
    </dist:module>

    <application>
        <!--
        Registers ActiveRecallScreen into ActiveRecallSessionEntry before Application.onCreate().
        This lets :app navigate to ActiveRecallScreen without importing it directly,
        preserving the dynamic-feature dependency direction.
        -->
        <provider
            android:name=".ActiveRecallSessionInitProvider"
            android:authorities="${applicationId}.active_recall_init"
            android:exported="false" />
    </application>

</manifest>
